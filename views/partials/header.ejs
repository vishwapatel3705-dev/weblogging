<!DOCTYPE html>
<html>
<head>
  <title>StoryBoard Blog</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="site-header">
    <nav class="nav-shell">
      <a class="brand" href="/">StoryBoard</a>
      <div class="nav-actions">
        <% if (currentUser) { %>
          <span class="welcome">Hi, <%= currentUser.username %></span>
          <a class="button button-primary" href="/new">Write</a>
          <form action="/logout" method="POST" class="inline-form">
            <button class="button button-ghost" type="submit">Logout</button>
          </form>
        <% } else { %>
          <a class="button button-ghost" href="/login">Login</a>
          <a class="button button-primary" href="/register">Register</a>
        <% } %>
      </div>
    </nav>
  </header>
  <main class="page-shell">
